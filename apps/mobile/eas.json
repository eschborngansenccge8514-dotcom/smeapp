{
  "cli": { "version": ">= 10.0.0" },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": { "buildType": "apk" }
    },
    "production": {
      "autoIncrement": true
    },
    "production-example-merchant": {
      "autoIncrement": true,
      "env": { "BRAND": "example-merchant" }
    }
  },
  "submit": {
    "production": {
      "ios": { "appleId": "your@email.com", "ascAppId": "YOUR_APP_STORE_ID" },
      "android": { "serviceAccountKeyPath": "./google-play-key.json", "track": "production" }
    }
  }
}
